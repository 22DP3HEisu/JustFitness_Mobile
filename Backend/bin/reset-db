#!/usr/bin/env node
/**
 * Database reset script
 * Drops all tables and recreates them with fresh structure
 */

require('dotenv').config();
const { db } = require('../lib/database');
const UserModel = require('../lib/userModel');
const MuscleGroupModel = require('../lib/muscleGroupModel');
const ExerciseModel = require('../lib/exerciseModel');
const WorkoutModel = require('../lib/workoutModel');

async function resetDatabase() {
  try {
    console.log('🔧 Starting database reset...');
    
    // Test connection
    console.log('📡 Testing database connection...');
    const isConnected = await db.testConnection();
    
    if (!isConnected) {
      console.error('❌ Database connection failed. Please check your configuration.');
      process.exit(1);
    }
    
    // Drop tables in reverse order of creation (respecting foreign keys)
    console.log('⚠️  Dropping existing tables...');
    
    const tablesToDrop = [
      'workout_exercises',
      'exercise_muscle_groups',
      'workouts',
      'exercises',
      'muscle_groups',
      'users'
    ];

    for (const table of tablesToDrop) {
      try {
        await db.executeQuery(`DROP TABLE IF EXISTS ${table}`);
        console.log(`✓ Dropped ${table} table`);
      } catch (error) {
        console.warn(`⚠️  Could not drop ${table} table:`, error.message);
      }
    }
    
    // Create tables in proper order
    console.log('📋 Creating fresh tables...');
    await UserModel.createTable();
    await MuscleGroupModel.createTable();
    await ExerciseModel.createTable();
    await WorkoutModel.createTable();

    // Populate muscle groups
    console.log('📊 Populating muscle groups...');
    const muscleGroups = [
      { name: 'Chest', description: 'Pectoral muscles including the pectoralis major and minor' },
      { name: 'Back', description: 'Muscles of the back including the latissimus dorsi' },
      { name: 'Shoulders', description: 'Deltoid muscles (anterior, lateral, and posterior)' },
      { name: 'Arms', description: 'Biceps, triceps, and forearm muscles' },
      { name: 'Triceps', description: 'The three-headed muscle at the back of the upper arm' },
      { name: 'Biceps', description: 'The two-headed muscle at the front of the upper arm' },
      { name: 'Forearms', description: 'Muscles of the forearm including flexors and extensors' },
      { name: 'Core', description: 'Abdominal and lower back muscles' },
      { name: 'Legs', description: 'Quadriceps, hamstrings, calves, and other leg muscles' },
      { name: 'Glutes', description: 'Gluteal muscles including the gluteus maximus, medius, and minimus' }
    ];

    for (const mg of muscleGroups) {
      try {
        await MuscleGroupModel.create(mg.name, mg.description);
        console.log(`✓ Created muscle group: ${mg.name}`);
      } catch (error) {
        console.warn(`⚠️  Could not create muscle group ${mg.name}:`, error.message);
      }
    }
    
    console.log('✅ Database reset completed successfully!');
    console.log('💡 All tables have been recreated and muscle groups populated.');
    
    process.exit(0);
    
  } catch (error) {
    console.error('❌ Database reset failed:', error);
    process.exit(1);
  }
}

// Run reset if script is executed directly
if (require.main === module) {
  resetDatabase();
}

module.exports = { resetDatabase };
