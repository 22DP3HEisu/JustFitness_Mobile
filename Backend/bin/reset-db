#!/usr/bin/env node

require('dotenv').config();
const { db } = require('../lib/database');

const Models = {
  UserModel: require('../lib/DbModels/userModel'),
  RefreshTokenModel: require('../lib/DbModels/refreshTokenModel'),
  UserSettingsModel: require('../lib/DbModels/userSettingsModel'),
  WeightHistoryModel: require('../lib/DbModels/weightHistoryModel'),
  MuscleGroupModel: require('../lib/DbModels/muscleGroupModel'),
  ExerciseModel: require('../lib/DbModels/exerciseModel'),
  WorkoutModel: require('../lib/DbModels/workoutModel'),
  WorkoutExerciseModel: require('../lib/DbModels/workoutExerciseModel'),
  ExerciseSetModel: require('../lib/DbModels/exerciseSetModel'),
  WorkoutLogModel: require('../lib/DbModels/workoutLogModel'),
  ExerciseLogModel: require('../lib/DbModels/exerciseLogModel'),
  SetLogModel: require('../lib/DbModels/SetLogModel'),
  FoodModel: require('../lib/DbModels/foodModel'),
  MealModel: require('../lib/DbModels/mealModel'),
  WaterLogModel: require('../lib/DbModels/waterLogModel'),
};

async function resetDatabase() {
  try {
    console.log('🔧 Starting database reset...');

    // Test connection
    console.log('📡 Testing database connection...');
    const isConnected = await db.testConnection();

    if (!isConnected) {
      console.error('❌ Database connection failed.');
      process.exit(1);
    }

    // =========================
    // DROP TABLES (ALL TABLES)
    // =========================
    console.log('⚠️ Dropping existing tables...');

    // Deaktivizē ārējās atslēgas, lai varētu nolabot tabulas jebkādā secībā
    await db.executeQuery('SET FOREIGN_KEY_CHECKS=0');

    try {
      // Iegūst visus tabulas vārdus
      const result = await db.selectAll("SELECT TABLE_NAME FROM information_schema.TABLES WHERE TABLE_SCHEMA = DATABASE()");
      
      for (const row of result) {
        const table = row.TABLE_NAME;
        try {
          await db.executeQuery(`DROP TABLE IF EXISTS ${table}`);
          console.log(`✓ Dropped ${table}`);
        } catch (err) {
          console.warn(`⚠️ Could not drop ${table}:`, err.message);
        }
      }
    } finally {
      // Aktivizē ārējās atslēgas atpakaļ
      await db.executeQuery('SET FOREIGN_KEY_CHECKS=1');
    }

    // =========================
    // CREATE TABLES (NORMAL ORDER)
    // =========================
    console.log('📋 Creating fresh tables...');

    for (const modelName in Models) {
      const model = Models[modelName];

      if (model?.createTable) {
        try {
          await model.createTable();
          console.log(`✓ Created ${modelName.replace('Model', '')}`);
        } catch (error) {
          console.error(`❌ Error creating ${modelName}:`, error);
          throw error;
        }
      }
    }

    // =========================
    // SEED DATA
    // =========================
    console.log('📊 Populating muscle groups...');

    const muscleGroups = [
      { name: 'Chest', description: 'Pectoral muscles' },
      { name: 'Lats', description: 'Latissimus dorsi' },
      { name: 'Rhomboids', description: 'Upper back muscles' },
      { name: 'Traps', description: 'Trapezius muscles' },
      { name: 'Lower Back', description: 'Erector spinae' },
      { name: 'Biceps', description: 'Front arm muscles' },
      { name: 'Triceps', description: 'Back arm muscles' },
      { name: 'Forearms', description: 'Lower arm muscles' },
      { name: 'Quadriceps', description: 'Front thigh muscles' },
      { name: 'Hamstrings', description: 'Back thigh muscles' },
      { name: 'Calves', description: 'Lower leg muscles' },
      { name: "Adductors", description: "Inner thigh muscles" },
      { name: "Abductors", description: "Outer thigh muscles" },
      { name: 'Shoulders', description: 'Deltoids' },
      { name: 'Core', description: 'Abs & lower back' },
      { name: 'Glutes', description: 'Glute muscles' }
    ];

    const MuscleGroupModel = Models.MuscleGroupModel;

    for (const mg of muscleGroups) {
      try {
        await MuscleGroupModel.create(mg.name, mg.description);
        console.log(`✓ Created muscle group: ${mg.name}`);
      } catch (err) {
        console.warn(`⚠️ Could not create ${mg.name}:`, err.message);
      }
    }

    console.log('✅ Database reset completed!');
    process.exit(0);

  } catch (error) {
    console.error('❌ Reset failed:', error);
    process.exit(1);
  }
}

if (require.main === module) {
  resetDatabase();
}

module.exports = { resetDatabase };
