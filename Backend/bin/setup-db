#!/usr/bin/env node
/**
 * Database setup script
 * Creates necessary tables and initial data
 */

require('dotenv').config();
const { db } = require('../lib/database');
const UserModel = require('../lib/DbModels/userModel');
const MuscleGroupModel = require('../lib/DbModels/muscleGroupModel');
const ExerciseModel = require('../lib/DbModels/exerciseModel');
const WorkoutModel = require('../lib/DbModels/workoutModel');
const CompletedWorkoutModel = require('../lib/DbModels/completedWorkoutModel');
const MealModel = require('../lib/DbModels/mealModel');
const FoodModel = require('../lib/DbModels/foodModel');

async function setupDatabase() {
  try {
    console.log('🔧 Starting database setup...');
    
    // Test connection
    console.log('📡 Testing database connection...');
    const isConnected = await db.testConnection();
    
    if (!isConnected) {
      console.error('❌ Database connection failed. Please check your configuration.');
      process.exit(1);
    }
    
    // Create tables (order matters due to foreign key dependencies)
    console.log('📋 Creating tables...');
    await UserModel.createTable();
    await MuscleGroupModel.createTable();
    await ExerciseModel.createTable();
    await WorkoutModel.createTable();
    await CompletedWorkoutModel.createTable();
    await FoodModel.createTable();
    await MealModel.createTable();
    
    console.log('✅ Database setup completed successfully!');
    
  } catch (error) {
    console.error('❌ Database setup failed:', error);
    process.exit(1);
  }
}

// Run setup if script is executed directly
if (require.main === module) {
  setupDatabase();
}

module.exports = { setupDatabase };